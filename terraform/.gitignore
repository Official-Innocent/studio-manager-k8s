# Sensitive variable files — NEVER commit these
secrets.tfvars
*.tfvars.local

# Terraform state — managed remotely in S3, never commit locally
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
*.tfplan
